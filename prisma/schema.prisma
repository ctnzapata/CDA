// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id
  password  String
  nombres   String?
  rol       String   @default("TECNICO") // 'ADMIN' o 'TECNICO'
  intentos  Int      @default(0)
  bloqueado Boolean  @default(false)
  
  citas     Cita[]
}

model Propietario {
  id            String     @id // Trataremos la Cédula/NIT como llave primaria
  tipoDocumento String     // 'CC', 'NIT', 'CE'
  nombres       String
  apellidos     String
  telefono      String
  email         String
  direccion     String
  
  vehiculos     Vehiculo[]
  citas         Cita[]

  // Índice para búsquedas rápidas
  @@index([nombres, apellidos])
}

model Vehiculo {
  placa         String      @id
  tipoVehiculo  String      // 'Carro' o 'Moto'
  marca         String
  linea         String
  modelo        Int         // Cambiado a entero
  color         String
  numeroChasis  String?     // Opcional
  numeroMotor   String?
  tieneDeuda    Boolean     @default(false)
  
  propietarioId String
  propietario   Propietario @relation(fields: [propietarioId], references: [id], onDelete: Restrict)
  
  citas         Cita[]

  // Índice para búsquedas rápidas por Placa
  @@index([placa])
  @@index([propietarioId])
}

model Cita {
  id            String   @id @default(uuid())
  fecha         DateTime // Guardará la fecha (ej: 2024-05-15)
  horaSlot      String   // Formato "HH:mm" (ej: "08:00")
  estado        String   @default("PENDIENTE") // PENDIENTE, EN_PISTA, COMPLETADA, CANCELADA
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  placaVehiculo String
  propietarioId String?
  usuarioId     String?  // Inspector o recepcionista que atendió/agendó

  vehiculo      Vehiculo     @relation(fields: [placaVehiculo], references: [placa], onDelete: Restrict)
  propietario   Propietario? @relation(fields: [propietarioId], references: [id], onDelete: SetNull)
  usuario       User?        @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  // Índices para optimizar búsquedas por agenda y evitar colisiones
  @@index([fecha, horaSlot])
  @@index([estado])
  @@index([placaVehiculo])
}

model RechazoCita {
  id            String   @id @default(uuid())
  placaVehiculo String
  fechaIntento  DateTime @default(now())
  motivo        String
}

